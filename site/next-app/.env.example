# PageShot — environment variables
#
# SERVER-ONLY. These two variables are consumed exclusively by the Node-runtime
# route handler at `app/api/screenshot/[pageId]/route.ts` and by
# `lib/sitecore-token.ts`. They must NEVER be prefixed with `NEXT_PUBLIC_` — that
# would inline them into the client bundle. See ADR-0002 / § 4c-1 / FR-04 / NFR-S-01.
#
# To run the full capture flow locally or on Vercel, copy this file to
# `.env.local` (which is gitignored by .gitignore → `.env*.local`) and fill in
# the two values with a Sitecore Cloud Portal Automation Client's client_id /
# client_secret. Acquisition protocol: auth.md § 0.
#
# For E1 scaffold-only work the values can be left blank — the panel UI does
# not call the Agent API until E3 lands.

SITECORE_DEPLOY_CLIENT_ID=
SITECORE_DEPLOY_CLIENT_SECRET=
